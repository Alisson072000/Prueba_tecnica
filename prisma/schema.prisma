generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  assignee    String
  status      TaskStatus @default(TODO)
  createdAt   DateTime   @default(now())
  dueDate     DateTime?
}
